COSMOS_CONNECTION_STRING=AccountEndpoint=
# Optional alternative to connection string:
# COSMOS_ENDPOINT=
# COSMOS_KEY=

COSMOS_DATABASE=calcul8tr_prod
COSMOS_CONTAINER=cards_catalog

# Optional defaults:
CARDSYNC_GAME=ua
CARDSYNC_BATCH_SIZE=100
CARDSYNC_CONCURRENCY=4
CARDSYNC_DRY_RUN=false

# Union Arena source (Exburst/Supabase REST)
EXBURST_API_BASE=https://auth.exburst.dev
EXBURST_API_KEY=
EXBURST_BEARER_TOKEN=
EXBURST_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
