{
  "name": "whatfees",
  "version": "1.0.226",
  "description": "whatfees PWA",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/stamp-sw-version.mjs",
    "build:prod": "vite build && node scripts/stamp-sw-version.mjs && node scripts/obfuscate.mjs",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:fast": "vitest run --config vitest.fast.config.mjs",
    "test:fast:watch": "vitest --config vitest.fast.config.mjs",
    "test:vue": "vitest run --config vitest.vue.config.mjs",
    "test:vue:watch": "vitest --config vitest.vue.config.mjs",
    "test:api": "npm --prefix apps/api run test",
    "test:api:coverage": "npm --prefix apps/api run test:coverage",
    "test:all": "npm run test && npm run test:api",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:coverage:frontend:hotpaths": "vitest run --config vitest.coverage-hotpaths.config.mjs --coverage",
    "test:coverage:all": "node scripts/run-parallel.mjs --task frontend::npm run test:coverage:frontend:hotpaths --task api::npm run test:api:coverage && npm run coverage:hotpaths",
    "coverage:hotpaths": "node scripts/coverage-hotpaths.mjs",
    "test:coverage:hotpaths": "npm run test:coverage:all",
    "security:scan": "node scripts/security-scan.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/run-parallel.mjs --task security::npm run security:scan --task test::npm run test --task typecheck::npm run typecheck && npm run build",
    "assetlinks": "node scripts/generate-assetlinks.mjs",
    "release:play": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-google-play.ps1",
    "api:install": "npm --prefix apps/api install",
    "api:build": "npm --prefix apps/api run build",
    "api:start": "npm --prefix apps/api run start:build",
    "backend:start": "node scripts/run-parallel.mjs --task api::npm --prefix apps/api run start:build --task realtime::npm --prefix apps/realtime run start:dev",
    "realtime:install": "npm --prefix apps/realtime install",
    "realtime:build": "npm --prefix apps/realtime run build",
    "realtime:start": "npm --prefix apps/realtime run start:dev",
    "realtime:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap-realtime.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unschoolers/WhatFees.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Unschoolers/WhatFees/issues"
  },
  "homepage": "https://github.com/Unschoolers/WhatFees#readme",
  "dependencies": {
    "chart.js": "^4.5.1",
    "driver.js": "^1.4.0",
    "vue": "^3.5.28",
    "vuetify": "^3.11.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "javascript-obfuscator": "^5.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^3.2.4"
  }
}
